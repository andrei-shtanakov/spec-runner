.idea/
.vscode/
*.swp
*.swo

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checking
.mypy_cache/
.pyrefly/

# OS
.DS_Store
Thumbs.db

# Local config
*.local.yaml
.env

# Logs
*.log
logs/

# Claude templates
.claude/
# Runtime spec workspace (repo root) — `spec/` matches at any depth, so carve out
# versioned gated-spec bundles under docs/plans/ (e.g. spec-runner-c1-stages-profile)
spec/
!docs/plans/*/spec/
!docs/plans/*/spec/**

COWORK_CONTEXT.md
_cowork_output/
